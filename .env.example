# ── Supabase (Project Settings → API) ───────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# ── Groq — IA gratuita (console.groq.com/keys) ──────────────────
GROQ_API_KEY=gsk_xxxxxxxx
# Opcional — modelo usado pela IA. Padrao: llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile

# ── YouTube Data API v3 (console.cloud.google.com) ──────────────
# Opcional. Sem ela, as receitas mostram um link de busca no YouTube
# em vez do video embutido.
YOUTUBE_API_KEY=

# URL publica do app (em producao, a URL do Vercel)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
